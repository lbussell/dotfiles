# ~/.bash_aliases — sourced from ~/.bashrc

# User aliases (chezmoi-generated)
[ -f ~/.config/shell/aliases.bash ] && . ~/.config/shell/aliases.bash

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

# reload alias for convenience
alias reload="source ~/.bash_aliases"

# Fix colors for light theme
Set-PSReadLineOption -Colors @{
    ContinuationPrompt      = "`e[39m"
    Default                 = "`e[39m"
    Member                  = "`e[39m"
    Number                  = "`e[39m"
    Type                    = "`e[39m"
    ListPredictionSelected  = "`e[7m"
}

{{ if eq .chezmoi.os "windows" -}}
# Tell Windows Terminal about the CWD using OSC 9;9
function prompt {
    $loc = $executionContext.SessionState.Path.CurrentLocation;
    $out = ""
    if ($loc.Provider.Name -eq "FileSystem") {
        $out += "$([char]27)]9;9;`"$($loc.ProviderPath)`"$([char]27)\"
    }
    $out += "PS $loc$('>' * ($nestedPromptLevel + 1)) ";
    return $out
}

{{ end -}}
if (-not $env:SOURCE_DIR) {
{{ if eq .chezmoi.os "windows" }}
    $devDriveSourceDir = 'D:\src'
    $env:SOURCE_DIR = if (Test-Path -LiteralPath $devDriveSourceDir -PathType Container) {
        $devDriveSourceDir
    }
    else {
        Join-Path $HOME 'src'
    }
{{ else }}
    $env:SOURCE_DIR = Join-Path $HOME 's'
{{ end }}
}

# Source functions from a separate file.
. (Join-Path $HOME '.config/powershell/functions.ps1')

# Source aliases from a separate file.
. (Join-Path $HOME '.pwsh_aliases.ps1')
{{ if eq .chezmoi.os "windows" }}
# Prefer dotnet installed by dotnetup when it is available.
$dotnetUpBin = Join-Path $HOME '.dotnetup'
$dotnetUpRoot = Join-Path $HOME 'AppData\Local\dotnet'
$dotnetUpExecutable = Join-Path $dotnetUpRoot 'dotnet.exe'
if (Test-Path -LiteralPath $dotnetUpExecutable -PathType Leaf) {
    $env:DOTNET_ROOT = $dotnetUpRoot
    $pathEntries = @($env:PATH -split [IO.Path]::PathSeparator)
    $prependEntries = @(
        @($dotnetUpBin, $dotnetUpRoot) |
            Where-Object { (Test-Path -LiteralPath $_ -PathType Container) -and $_ -notin $pathEntries }
    )
    if ($prependEntries) {
        $env:PATH = (@($prependEntries) + @($pathEntries)) -join [IO.Path]::PathSeparator
    }
}
{{ end -}}

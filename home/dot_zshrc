# .zshrc

# Prompt: green username, directory, and %
setopt PROMPT_SUBST
PROMPT='%F{green}[%f%F{green}%n%f %1~%F{green}]%f%F{green}%# %f'

# Reload zshrc
alias reload='source ~/.zshrc'

# Colors in ls
export CLICOLOR=1

# Use neovim instead of vim
export EDITOR='nvim'
alias vim='nvim'

# .NET SDK tools
export PATH="$PATH:/Users/loganbussell/.dotnet/tools"

# Atuin configuration
eval "$(atuin init zsh)"

# ~/.local/bin for standalone tools
export PATH="$HOME/.local/bin:$PATH"

# BEGIN Agency MANAGED BLOCK
if [[ ":${PATH}:" != *":/Users/loganbussell/.config/agency/CurrentVersion:"* ]]; then
    export PATH="/Users/loganbussell/.config/agency/CurrentVersion:${PATH}"
fi
# END Agency MANAGED BLOCK

[ -f "$HOME/Library/Application Support/dnvm/env" ] && . "$HOME/Library/Application Support/dnvm/env"
[ -f "$HOME/.zsh_aliases" ] && . "$HOME/.zsh_aliases"
[ -f "$HOME/.config/shell/git-functions.sh" ] && . "$HOME/.config/shell/git-functions.sh"

# Added by get-aspire-cli.sh
export PATH="$HOME/.aspire/bin:$PATH"

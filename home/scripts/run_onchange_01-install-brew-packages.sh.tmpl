{{- if and (ne .chezmoi.os "windows") (eq .package_manager "brew") -}}
#!/bin/bash
{{ template "install-package-header" }}
{{ template "brew-shellenv" . }}

log "Installing Homebrew packages via brew bundle"
{{ $excludes := get .homebrew.exclude .chezmoi.username | default list -}}
brew bundle --file=/dev/stdin <<EOF
{{ range .homebrew.unix.formulae -}}
{{ if not (has . $excludes) -}}
brew "{{ . }}"
{{ end -}}
{{ end -}}
{{ range .homebrew.unix.casks -}}
{{ if not (has . $excludes) -}}
cask "{{ . }}"
{{ end -}}
{{ end -}}
{{- if eq .chezmoi.os "darwin" }}
{{ range .homebrew.darwin.formulae -}}
{{ if not (has . $excludes) -}}
brew "{{ . }}"
{{ end -}}
{{ end -}}
cask "ghostty@tip"
cask "git-credential-manager"
cask "barutsrb/tap/omniwm"
{{ end -}}
EOF

log "Homebrew packages installed successfully"
{{- end -}}

{{- if and (eq .chezmoi.os "linux") (eq .package_manager "apt") -}}
#!/bin/bash
{{ template "install-package-header" }}

log "Installing APT packages"
sudo apt-get update
sudo apt-get install -y {{ join " " .apt.packages }}
log "APT packages installed successfully"
{{- end -}}

{{- if and (eq .chezmoi.os "linux") (eq .package_manager "dnf") -}}
#!/bin/bash
{{ template "install-package-header" }}

log "Installing DNF packages"
sudo dnf install -y {{ join " " .dnf.packages }}
log "DNF packages installed successfully"
{{- end -}}
